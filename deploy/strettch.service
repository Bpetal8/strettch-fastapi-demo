[Unit]
Description=Strettch FastAPI Service
After=network.target

[Service]
User=www-data
Group=www-data

WorkingDirectory=/var/www/strettch-fastapi-demo

Environment="APP_ENV=production"

ExecStart=/var/www/strettch-fastapi-demo/venv/bin/gunicorn app.main:app --workers 2 --worker-class uvicorn.workers.UvicornWorker --bind 127.0.0.1:8000

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target