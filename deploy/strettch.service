[Unit]
Description=Strettch FastAPI Service
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/strettch-fastapi-demo
Environment="PATH=/home/ubuntu/strettch-fastapi-demo/venv/bin"
Environment="APP_ENV=production"

ExecStart=/home/ubuntu/strettch-fastapi-demo/venv/bin/gunicorn \
    --workers 2 \
    --worker-class uvicorn.workers.UvicornWorker \
    --bind 127.0.0.1:8000 \
    app.main:app

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target